# ─── Orah ────────────────────────────────────────────────────────────────────
# All values below are placeholders. Real values come from Phase 0 discovery
# (see docs/orah-discovery.md) and from Shayne's Orah admin console.
ORAH_API_KEY=
ORAH_BASE_URL=https://open-api-ireland.orah.com
HEALTH_CENTER_LOCATION_ID=
# Encoding for "no physical activity" — pastoral record type id, tag, or
# custom field. Confirm in Phase 0.
NO_PA_RECORD_TYPE_ID=

# ─── NextAuth (Auth.js v5) / Google OAuth ────────────────────────────────────
# Generate AUTH_SECRET locally with:  openssl rand -base64 32
AUTH_SECRET=
AUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
ALLOWED_DOMAIN=las.ch

# ─── Vercel KV ───────────────────────────────────────────────────────────────
# These are auto-injected by Vercel when KV is connected to the project.
# Leave blank locally unless you've provisioned KV.
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=
KV_URL=

# ─── Resend (email) ──────────────────────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=dashboard@las.ch

# ─── Cron (Phase 6, optional) ────────────────────────────────────────────────
CRON_SECRET=
FRIDAY_RECIPIENTS=

# ─── App ─────────────────────────────────────────────────────────────────────
# When set to "1", server routes return mock data instead of calling Orah.
# Useful for local dev before Phase 0 is complete.
USE_MOCK_DATA=1
