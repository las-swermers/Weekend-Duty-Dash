# ─── Orah ────────────────────────────────────────────────────────────────────
# Auth confirmed 2026-04-28: header is `Authorization: Bearer <ORAH_API_KEY>`,
# all endpoints are POST under /open-api/<resource>/<action>.
# See docs/orah-discovery.md for the full surface.
ORAH_API_KEY=
ORAH_BASE_URL=https://open-api-ireland.orah.com

# Health Center location ids — comma-separated, since LAS has a per-dorm
# HC layout (e.g. "Savoy Health Center", "BE Nursery"). Visit
# /api/orah/locations after deploy to find ids. If unset, the app
# auto-detects locations whose name matches built-in HC patterns
# (Health Center / Nursery / Infirmary / Sick Bay / Wellness) plus any
# extra patterns supplied via HEALTH_CENTER_NAME_PATTERNS (CSV).
HEALTH_CENTER_LOCATION_IDS=
HEALTH_CENTER_NAME_PATTERNS=

# Additional location ids that count as "in HC" for the Friday rollup —
# e.g. rest-in-room pass locations. Comma-separated numeric ids.
HC_REST_LOCATION_IDS=

# Substring matched (case-insensitive) against location.name to flag a
# record as a rest-in-room pass when a numeric id isn't pinned.
# Default "rest" catches "Rest in Room", "Resting", etc.
HC_REST_LOCATION_PATTERN=rest

# Encoding for "no physical activity" — pastoral category name to match
# against pastoral_category.name on records. Default guess only; replace
# once we see what categories LAS actually uses.
NO_PA_CATEGORY_NAME=No Physical Activity

# ─── NextAuth (Auth.js v5) / Google OAuth ────────────────────────────────────
# Generate AUTH_SECRET locally with:  openssl rand -base64 32
AUTH_SECRET=
AUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
ALLOWED_DOMAIN=las.ch

# ─── Vercel KV (legacy fallback) ─────────────────────────────────────────────
# Auto-injected by Vercel when KV is connected to the project. Only used
# when LAUNCHPAD_SHEET_CSV_URL is not set.
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=
KV_URL=

# ─── Launchpad source (Google Sheet) ─────────────────────────────────────────
# When set, the launchpad reads its tile list from a published Google Sheet
# CSV instead of Vercel KV. The sheet must be either published to web or
# shared as "anyone with the link can view" (or with the @las.ch domain).
#
# Sheet schema (header row required, lower-case headers):
#   name,url,icon,order
#
# Only `name` and `url` are required. `icon` defaults to "link" if blank.
# `order` is optional; rows render in sheet order if omitted. Categories
# are no longer used — the launchpad renders as one flat grid.
#
# Sheet edits propagate to the dashboard within ~5 minutes.
LAUNCHPAD_SHEET_CSV_URL=
# Optional: link the "Edit in Sheets" button on the dashboard to the
# human-editable sheet URL (the docs.google.com/.../edit URL).
LAUNCHPAD_SHEET_EDIT_URL=

# ─── Launchpad write-back (optional, admin only) ─────────────────────────────
# When all three are set, designated admins see an "+ Add link" tile on
# the launchpad. The dashboard forwards POSTs to a Google Apps Script
# attached to the sheet (see docs/runbook.md "Apps Script for adding
# links" for the script and deployment steps).
#
# LAUNCHPAD_ADMIN_EMAILS  comma-separated emails who can use Add
# LAUNCHPAD_WRITE_URL     Apps Script web app deployment URL
# LAUNCHPAD_WRITE_TOKEN   shared secret matching the SHARED_SECRET in
#                         the script. Generate with:
#                         openssl rand -hex 24
LAUNCHPAD_ADMIN_EMAILS=
LAUNCHPAD_WRITE_URL=
LAUNCHPAD_WRITE_TOKEN=

# ─── Resend (email) ──────────────────────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=dashboard@las.ch

# ─── Analytics access control ────────────────────────────────────────────────
# Optional. Comma-separated emails allowed on /analytics. When empty,
# anyone passing the app-wide domain check can view analytics.
# Pastoral notes can be sensitive — restrict this to AOC / pastoral leads.
ANALYTICS_ALLOWED_EMAILS=

# ─── Cron (Phase 6, optional) ────────────────────────────────────────────────
CRON_SECRET=
FRIDAY_RECIPIENTS=

# ─── App ─────────────────────────────────────────────────────────────────────
# When set to "1", server routes return mock data instead of calling Orah.
# Leave blank in production — only the no-PA / travel / trips routes still
# fall back to mock until their integrations land. Health center is live.
USE_MOCK_DATA=
